# --- Required ---

# Neon Postgres connection string (Dashboard -> Connection Details -> copy the pooled URL)
DATABASE_URL="postgres://user:password@host/dbname?sslmode=require"

# The single password you will log in with
APP_PASSWORD="choose-a-strong-password"

# Any long random string; used to sign the session cookie.
# Generate one with:  node -e "console.log(crypto.randomBytes(32).toString('hex'))"
SESSION_SECRET="replace-with-long-random-string"

# --- Optional: Teller (bank transaction sync) ---
# Create a free app at https://teller.io (developer tier: 100 connections free).
NEXT_PUBLIC_TELLER_APP_ID=""
# sandbox | development | production
NEXT_PUBLIC_TELLER_ENV="sandbox"

# Teller client certificate (required for development/production environments, NOT sandbox).
# Download cert + key from the Teller dashboard, then base64-encode each file:
#   Windows PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes("certificate.pem"))
TELLER_CERT_B64=""
TELLER_KEY_B64=""

# If transaction debits/credits appear inverted in match suggestions, flip this to "negative"
TELLER_DEBIT_SIGN="positive"

# --- Optional: protects the daily cron endpoint on Vercel ---
CRON_SECRET=""
